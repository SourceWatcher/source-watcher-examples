{
    "$schema": "https://raw.githubusercontent.com/TheCocoTeam/source-watcher-api/master/pipeline.schema.json",
    "steps": [
        {
            "type": "extractor",
            "name": "Csv",
            "options": {
                "filePath": "https://people.sc.fsu.edu/~jburkardt/data/csv/oscar_age_female.csv",
                "columns": ["Year", "Name", "Movie"],
                "delimiter": ",",
                "enclosure": "\""
            },
            "x": 80,
            "y": 100
        },
        {
            "type": "transformer",
            "name": "ConvertCase",
            "options": {
                "columns": ["Year", "Name", "Movie"],
                "mode": "lower",
                "encoding": "UTF-8"
            },
            "x": 280,
            "y": 180
        },
        {
            "type": "transformer",
            "name": "RenameColumns",
            "options": {
                "columns": {
                    "movie": "preferred_movie"
                }
            },
            "x": 480,
            "y": 100
        },
        {
            "type": "loader",
            "name": "Database",
            "options": {
                "driver": "pdo_sqlite",
                "tableName": "people",
                "path": "/var/www/html/.source-watcher/csv-lower-rename.db",
                "memory": false
            },
            "x": 680,
            "y": 180
        }
    ]
}
